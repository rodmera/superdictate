def load_config():
    if os.path.exists(CONFIG_FILE):
        try:
            with open(CONFIG_FILE, encoding='utf-8') as f:
                cfg = json.load(f)
            for key, val in DEFAULT_CONFIG.items():
                if key not in cfg:
                    cfg[key] = val
            return cfg
        except Exception:
            pass
    try:
        with open(CONFIG_FILE, 'w', encoding='utf-8') as f:
            json.dump(DEFAULT_CONFIG, f, ensure_ascii=False, indent=2)
    except Exception:
        pass
    return DEFAULT_CONFIG.copy()


def log_history(raw_text, refined_text, is_cmd, mode=None, cmd_type=None, cmd_args=None):
    try:
        record = {
            "ts": datetime.now().isoformat(),
            "raw": raw_text,
            "refined": refined_text,
            "mode": mode,
            "is_command": is_cmd,
            "command_type": cmd_type,
            "command_args": cmd_args
        }
        with open(HISTORY_FILE, "a", encoding="utf-8") as f:
            f.write(json.dumps(record, ensure_ascii=False) + "\n")
    except Exception:
        pass


def show_history(n=10):
    try:
        with open(HISTORY_FILE, encoding='utf-8') as f:
            lines = f.readlines()
    except FileNotFoundError:
        print("Sin historial todavía.")
        return
    records = [json.loads(l) for l in lines if l.strip()]
    for r in reversed(records[-n:]):
        ts = r.get('ts', '')[:16].replace('T', ' ')
        mode = r.get('mode') or 'default'
        if r.get('is_command'):
            print(f"[{ts}] [{mode}] CMD:{r.get('command_type')} — {r.get('command_args', '')}")
        else:
            text = (r.get('refined') or r.get('raw', ''))[:100]
            print(f"[{ts}] [{mode}] {text}")


def notify(msg, icon="audio-input-microphone", expire=2000):
    subprocess.run(["notify-send", "-t", str(expire), "-i", icon, "SuperDictate", msg])


def simulate_paste():
    """Simula Ctrl+Shift+V via teclado virtual a nivel de kernel (funciona en terminales)."""
    if not EVDEV_AVAILABLE:
        notify("evdev no instalado. Ejecuta: pip install evdev", "dialog-error", 5000)
        return
    try:
        ui = UInput()
        time.sleep(0.5)

        ui.write(e.EV_KEY, e.KEY_LEFTCTRL, 1);  ui.syn(); time.sleep(0.05)
        ui.write(e.EV_KEY, e.KEY_LEFTSHIFT, 1); ui.syn(); time.sleep(0.05)
        ui.write(e.EV_KEY, e.KEY_V, 1);         ui.syn(); time.sleep(0.05)
        ui.write(e.EV_KEY, e.KEY_V, 0);         ui.syn(); time.sleep(0.05)
        ui.write(e.EV_KEY, e.KEY_LEFTSHIFT, 0); ui.syn()
        ui.write(e.EV_KEY, e.KEY_LEFTCTRL, 0);  ui.syn()

        time.sleep(0.1)
        ui.close()
    except Exception as ex:
        notify(f"Error simulando pegado: {ex}", "dialog-error", 5000)


def _find_project(arg, projects_dir):
    """Matching por tokens en vez de substring libre."""
    arg_tokens = [t for t in re.split(r'[\s\-_]+', arg.lower()) if len(t) >= 3]
    if not arg_tokens:
        return None
    for folder in sorted(os.listdir(projects_dir), key=len):
        full_path = os.path.join(projects_dir, folder)
        if not os.path.isdir(full_path):
            continue
        folder_tokens = re.split(r'[\s\-_]+', folder.lower())
        for at in arg_tokens:
            for ft in folder_tokens:
                if at == ft or (len(at) >= 4 and ft.startswith(at)):
                    return folder
    return None


def _read_preloader_result(timeout=30):
    """Espera el resultado del pre-loader (max timeout segundos). Retorna dict o None."""
    open(READY_FILE, 'w').close()

    deadline = time.time() + timeout
    while time.time() < deadline:
        if os.path.exists(RESULT_FILE):
            try:
                with open(RESULT_FILE, encoding='utf-8') as f:
                    result = json.load(f)
                os.remove(RESULT_FILE)
                return result
            except Exception:
                break
        time.sleep(0.05)

    try:
        os.remove(READY_FILE)
    except FileNotFoundError:
        pass
    return None


def _copy_to_clipboard(text):
    proc = subprocess.Popen(["wl-copy"], stdin=subprocess.PIPE)
    proc.communicate(text.encode("utf-8"))
    return proc.returncode == 0


def stop_and_transcribe():
    pid = None
    try:
        with open(PID_FILE, "r") as f:
            pid = int(f.read().strip())
    except Exception:
        pass
    finally:
        try:
            os.remove(PID_FILE)
        except FileNotFoundError:
            pass

    if pid:
        try:
            os.kill(pid, 0)
            os.kill(pid, signal.SIGINT)
        except ProcessLookupError:
            pass

    os.system("pkill -f 'indicator.py'")
    time.sleep(0.2)

    # Leer estado persistido al iniciar grabación
    mode_key = "default"
    language = "es"
    append_mode = os.path.exists(APPEND_FILE)
    try:
        with open(MODE_FILE) as f:
            mode_key = f.read().strip()
        os.remove(MODE_FILE)
    except FileNotFoundError:
        pass
    try:
        with open(LANG_FILE) as f:
            language = f.read().strip()
        os.remove(LANG_FILE)
    except FileNotFoundError:
        pass
    try:
        os.remove(APPEND_FILE)
    except FileNotFoundError:
        pass

    config = load_config()
    vocabulary = config.get("vocabulary", [])
    mode = config.get("modes", {}).get(mode_key, {})
    mode_name = mode.get("name", mode_key)
    mode_prompt = mode.get("prompt", "")

    notify("Procesando...", "view-refresh", 5000)

    sys.path.insert(0, os.path.expanduser('~/.openclaw/workspace/skills/stt/scripts'))
    sys.path.insert(0, os.path.expanduser('~/.openclaw/workspace/skills'))

    try:
        # 1. Transcripción
        res = _read_preloader_result()
        if res is None:
            try:
                from stt import transcribe
                res = transcribe(AUDIO_FILE, model_size="turbo", language=language, beam_size=5)
            except Exception as transcribe_err:
                notify(f"Error en transcripcion: {transcribe_err}", "dialog-error", 4000)
                return

        raw_text = res.get("text", "")
        if not raw_text or "error" in res:
            notify(f"Error o silencio: {res.get('error', 'Audio vacio')}", "dialog-error", 3000)
            return

        log_history(raw_text=raw_text, refined_text="", is_cmd=False, mode=mode_key)

        # 2. Modo raw: bypass Gemini, pegar directamente
        if mode_key == "raw":
            final_text = raw_text
            if append_mode:
                existing = subprocess.run(['wl-paste'], capture_output=True, text=True).stdout.rstrip()
                if existing:
                    final_text = existing + " " + final_text
            if not _copy_to_clipboard(final_text):
                notify("Error al copiar al portapapeles", "dialog-error", 3000)
                return
            simulate_paste()
            notify(f"Texto insertado [Raw]", "emblem-default", 2000)
            return

        # 3. Análisis de intención con Gemini
        from shared_config import call_gemini_structured

        vocab_hint = (
            f" Vocabulario específico del usuario (respetar exactamente): {', '.join(vocabulary)}."
            if vocabulary else ""
        )
        mode_hint = f" {mode_prompt}" if mode_prompt else ""
        is_vault = mode_key == "vault"

        schema = {
            "type": "OBJECT",
            "properties": {
                "is_command": {
                    "type": "BOOLEAN",
                    "description": "El usuario da una orden al computador (ej. 'abre X', 'recuérdame Y', 'dile a Sherlock Z')?"
                },
                "command_type": {
                    "type": "STRING",
                    "description": "Si is_command=true, elige: 'open_project', 'open_vault', 'add_todo', 'ask_sherlock', 'search_vault'. Si no, vacío."
                },
                "command_args": {
                    "type": "STRING",
                    "description": "Argumento de la orden (nombre del proyecto, tarea, o mensaje para Sherlock)."
                },
                "refined_text": {
                    "type": "STRING",
                    "description": (
                        f"Si is_command=false, texto final. Corrige errores fonéticos de Whisper y nombres propios "
                        f"(Watson, Sherlock, Claude, TheIA, Entel, SuperDictate).{vocab_hint} "
                        f"Si el usuario enumera elementos, formatea como lista con saltos de línea reales.{mode_hint}"
                    )
                }
            },
            "required": ["is_command"]
        }

        if is_vault:
            schema["properties"]["note_title"] = {
                "type": "STRING",
                "description": "Título breve y descriptivo para la nota de Obsidian (máx 60 caracteres)."
            }

        prompt_llm = (
            f"Eres el cerebro de SuperDictate. Decide si el texto es un dictado pasivo o una orden activa.\n"
            f"Si el usuario pide a la máquina que haga algo (\"Abre el vault\", \"busca en mis notas X\", "
            f"\"recuérdame Y\", \"dile a Sherlock Z\"), marca is_command=true.\n"
            f"Si es texto para pegar o guardar, marca is_command=false.\n\n"
            f"Texto dictado (puede tener errores fonéticos de Whisper): \"{raw_text}\""
        )

        res_json = call_gemini_structured(prompt_llm, schema, model="gemini-3-flash-preview",
                                          temperature=0.1, timeout=45)
        if not res_json:
            raise Exception("Falla en API Gemini")

        log_history(
            raw_text=raw_text,
            refined_text=res_json.get("refined_text", ""),
            is_cmd=res_json.get("is_command", False),
            mode=mode_key,
            cmd_type=res_json.get("command_type"),
            cmd_args=res_json.get("command_args")
        )

        # 4. Ejecución
        if res_json.get("is_command"):
            cmd = res_json.get("command_type")
            arg = res_json.get("command_args", "")

            if cmd == "open_vault":
                subprocess.Popen(["xdg-open", "obsidian://open"],
                                  stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                notify("Abriendo Vault...", "emblem-default")

            elif cmd == "add_todo":
                sys.path.insert(0, os.path.expanduser('~/.openclaw/workspace/skills/todoist/scripts'))
                from todoist import add_task
                add_task(arg, due_string="today", project_name="Inbox")
                notify(f"Tarea anadida a Todoist:\n{arg}", "emblem-default", 4000)

            elif cmd == "search_vault":
                notify(f"Buscando en tus notas:\n{arg}", "emblem-default", 4000)
                sys.path.insert(0, os.path.expanduser('~/.openclaw/workspace/skills/obsidian-qa/scripts'))
                from vault_qa import ask_sources
                try:
                    ans = ask_sources(arg, sources=['vault', 'personal'], top_k=3)
                    answer_text = ans.get('answer', 'No encontre nada relevante.') if isinstance(ans, dict) else str(ans)
                except Exception as rag_err:
                    answer_text = f"Error en busqueda RAG: {rag_err}"
                try:
                    subprocess.Popen(['zenity', '--info',
                                      '--title', f'Resultados: {arg}',
                                      '--text', answer_text,
                                      '--width=600', '--height=400'])
                except FileNotFoundError:
                    tmp_ans = "/tmp/superdictate-vault-answer.txt"
                    with open(tmp_ans, "w") as fh:
                        fh.write(f"Busqueda: {arg}\n\n{answer_text}")
                    subprocess.Popen(["xdg-open", tmp_ans])

            elif cmd == "ask_sherlock":
                sherlock_to = config.get("sherlock_to", "")
                if not sherlock_to:
                    notify("sherlock_to no configurado en config.json", "dialog-error", 4000)
                else:
                    subprocess.Popen(
                        ["openclaw", "agent", "--to", sherlock_to, "--message", arg],
                        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
                    )
                    notify(f"Mensaje enviado a Sherlock:\n{arg}", "emblem-default", 4000)

            elif cmd == "open_project":
                projects_dir = os.path.expanduser("~/projects")
                folder = _find_project(arg, projects_dir)
                if folder:
                    subprocess.Popen(
                        ["xdg-open", os.path.join(projects_dir, folder)],
                        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                        start_new_session=True
                    )
                    notify(f"Proyecto abierto: {folder}", "emblem-default")
                else:
                    notify(f"Proyecto no encontrado: {arg}", "dialog-error")
            else:
                notify(f"Comando no reconocido: {cmd}", "dialog-warning")

        else:
            final_text = res_json.get("refined_text", raw_text)

            # Modo vault: guardar en Obsidian
            if is_vault:
                sys.path.insert(0, os.path.expanduser('~/.openclaw/workspace/skills/obsidian-capture/scripts'))
                try:
                    from capture import capture_note
                    ts = datetime.now().strftime("%Y%m%d%H%M")
                    title = res_json.get("note_title") or f"Nota de voz {ts}"
                    full_title = f"{ts} - {title}"
                    capture_note(full_title, final_text, tags=['unique', 'voice-note'])
                    notify(f"Nota guardada:\n{title}", "emblem-default", 3000)
                except Exception as vault_err:
                    notify(f"Error guardando en vault: {vault_err}", "dialog-error", 4000)
                return

            # Modo paste normal (con append opcional)
            if append_mode:
                existing = subprocess.run(['wl-paste'], capture_output=True, text=True).stdout.rstrip()
                if existing:
                    final_text = existing + " " + final_text

            if not _copy_to_clipboard(final_text):
                notify("Error al copiar al portapapeles", "dialog-error", 3000)
                return

            simulate_paste()
            notify(f"Texto insertado [{mode_name}]", "emblem-default", 2000)

    except Exception as err:
        notify(f"Falla del sistema: {err}", "dialog-error", 5000)


def start_recording(mode_override=None, append=False):
    config = load_config()
    mode_key = mode_override or config.get("default_mode", "default")
    language = config.get("language", "es")
    silence_timeout = config.get("silence_timeout")

    with open(MODE_FILE, 'w') as f:
        f.write(mode_key)
    with open(LANG_FILE, 'w') as f:
        f.write(language)
    if append:
        open(APPEND_FILE, 'w').close()

    for path in (RESULT_FILE, READY_FILE, MODEL_READY):
        try:
            os.remove(path)
        except FileNotFoundError:
            pass

    if silence_timeout:
        proc = subprocess.Popen(
            ["sox", "-t", "alsa", "default", "-r", "16000", "-c", "1", "-b", "16", AUDIO_FILE,
             "silence", "1", "0.1", "1%", "1", str(float(silence_timeout)), "1%"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
        watcher_path = os.path.join(os.path.dirname(os.path.realpath(__file__)), "silence_watcher.py")
        subprocess.Popen(
            [sys.executable, watcher_path, str(proc.pid), os.path.realpath(__file__)],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
    else:
        proc = subprocess.Popen(
            ["arecord", "-D", "default", "-f", "S16_LE", "-c", "1", "-r", "16000", AUDIO_FILE],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )

    with open(PID_FILE, "w") as f:
        f.write(str(proc.pid))

    preloader_path = os.path.join(os.path.dirname(os.path.realpath(__file__)), "preloader.py")
    if os.path.exists(preloader_path):
        subprocess.Popen([sys.executable, preloader_path],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    indicator_path = os.path.join(os.path.dirname(os.path.realpath(__file__)), "indicator.py")
    subprocess.Popen([sys.executable, indicator_path],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    mode_name = config.get("modes", {}).get(mode_key, {}).get("name", mode_key)
    suffix = " [+append]" if append else ""
    auto_suffix = " [auto-stop]" if silence_timeout else ""
    notify(f"Escuchando... [{mode_name}]{suffix}{auto_suffix}", "media-record", 10000)


if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--mode", default=None,
                        help="Modo de dictado: default, raw, email, chat, formal, notes, vault")
    parser.add_argument("--append", action="store_true",
                        help="Agregar el texto al portapapeles existente en vez de reemplazarlo")
    parser.add_argument("--history", nargs="?", const=10, type=int, metavar="N",
                        help="Mostrar las últimas N entradas del historial (default: 10)")
    args = parser.parse_args()

    if args.history is not None:
        show_history(args.history)
    elif os.path.exists(PID_FILE):
        stop_and_transcribe()
    else:
        os.system("killall arecord 2>/dev/null; pkill -f 'sox.*alsa' 2>/dev/null")
        start_recording(mode_override=args.mode, append=args.append)
